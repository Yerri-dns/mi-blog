---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import photos from "../data/photos.json";
const CLOUD_NAME = "dvdvy3emr"; // Tu Cloud Name real
---

<Layout title="Mr. Yerri | Inicio">
  <section
    class="flex flex-col items-start text-left space-y-2 mb-7 animate-fade-in"
  >
    <h1 class="text-2xl font-black tracking-tighter leading-none m-0">
      ¡Bienvenidos!
    </h1>
    <p></p>
    <p class="text-neutral dark:text-neutral max-w-xl leading-relaxed">
      Este es el comienzo de un pequeño proyecto. Aquí recopilaré algunas
      fotografías. Todas tendrán una pequeña descripción.
    </p>
  </section>
  <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      photos.map((photo) => (
        <article class="group overflow-hidden rounded-xl bg-neutral-100 dark:bg-neutral-900 transition-all hover:shadow-lg">
          <div class="aspect-4/3 overflow-hidden">
            <img
              src={`https://res.cloudinary.com/${CLOUD_NAME}/image/upload/q_auto,f_auto,w_800/${photo.id}.jpg`}
              alt={photo.title}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-bold text-lg text-black dark:text-white leading-tight">
                {photo.title}
              </h3>

              <button
                class="like-btn p-1 -m-1.5 rounded text-shadow-neutral-950 dark:text-neutral-50 transition-all hover:scale-110 active:scale-95 hover:text-red-500"
                aria-label="Me gusta"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="30"
                  height="30"
                  viewBox="0 0 23 23"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="heart-icon transition-colors"
                >
                  <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                </svg>
              </button>
            </div>

            <p class="text-sm text-neutral-700 dark:text-neutral-300 mt-2">
              {photo.description}
            </p>
          </div>
        </article>
      ))
    }
  </section>
</Layout>

<style>
  /* Una pequeña animación para que el texto aparezca suavemente */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
<script>
  const buttons = document.querySelectorAll(".like-btn");

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const icon = button.querySelector(".heart-icon");

      icon.classList.toggle("fill-red-500");
      icon.classList.toggle("stroke-red-500");
      icon.classList.toggle("text-red-500");
    });
  });
</script>
